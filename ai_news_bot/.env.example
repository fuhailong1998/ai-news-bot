# --- Feishu (choose one) ---
# A. Single webhook (legacy / simple)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
FEISHU_SECRET=

# B. Multiple webhooks (broadcast same news to many groups). Takes precedence over A.
#    JSON format:
#      FEISHU_WEBHOOKS=[{"url":"https://.../X","secret":"sX","name":"team-a"},{"url":"https://.../Y"}]
#    OR pipe/comma format:
#      FEISHU_WEBHOOKS=https://.../X|sX, https://.../Y|, https://.../Z|sZ
# FEISHU_WEBHOOKS=

# --- Optional LLM summarizer ---
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
