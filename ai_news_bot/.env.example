# --- Feishu (choose one) ---
# A. Single webhook (legacy / simple)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
FEISHU_SECRET=

# B. Multiple webhooks (broadcast same news to many groups). Takes precedence over A.
#    JSON format:
#      FEISHU_WEBHOOKS=[{"url":"https://.../X","secret":"sX","name":"team-a"},{"url":"https://.../Y"}]
#    OR pipe/comma format:
#      FEISHU_WEBHOOKS=https://.../X|sX, https://.../Y|, https://.../Z|sZ
# FEISHU_WEBHOOKS=

# --- Optional Telegram ---
# Simple: one bot, multiple chats
# TELEGRAM_BOT_TOKEN=1234567890:AAH...
# TELEGRAM_CHAT_IDS=-100123,@my_channel
# Advanced: multi-bot JSON (overrides the simple form)
# TELEGRAM_TARGETS=[{"bot_token":"...","chat_id":"-100","name":"team-a"}]

# --- Optional LLM summarizer ---
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
